{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "BricarOBD",
  "version": "2.0.10",
  "identifier": "com.bricarobd.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "BricarOBD",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost https://github.com https://objects.githubusercontent.com; img-src 'self' asset: https://asset.localhost data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "data/bricarobd.db"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v2Compatible"
  },
  "plugins": {
    "shell": {
      "open": "^https://(www\\.google\\.com|www\\.youtube\\.com|youtube\\.com)"
    },
    "updater": {
      "endpoints": [
        "https://github.com/DylanBricar/BricarOBD/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk4MUQ5MUI3MzBEMTU0MTYKUldRV1ZORXd0NUVkbUJMUzVvdXlxemdZTjFQSWMvSURkblFYa21GTWRTVTFPMjBJTmtwYnBUbzQK"
    }
  }
}
